# Required for both dev and deployment.
NEXT_PUBLIC_SANITY_PROJECT_ID=ihcvo75q
NEXT_PUBLIC_SANITY_DATASET=production

# Optional — defaults to "2026-06-22" if unset.
# NEXT_PUBLIC_SANITY_API_VERSION=2026-06-22

# Only needed for scripts/migrate-to-sanity.mjs (one-time bootstrap).
# Create at https://www.sanity.io/manage → Project → API → Tokens (Editor role).
# DO NOT commit a populated value.
# SANITY_API_READ_TOKEN=
